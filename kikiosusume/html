    // 画像エラー時に表示する代替画像のSVG(データURI)
    const fallbackImage = "data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2394a3b8'%3E%3Cpath d='M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z'/%3E%3C/svg%3E";

    // 現在のクイズ状態・タイマーを保持する変数
    let currentQuiz = null;
    let hintTimer = null; 

    // 2. 初期化処理
    document.addEventListener('DOMContentLoaded', () => {
        renderMenuGrid();
    });

    // 3. 画面切り替え関数
    function showScreen(screenName) {
        document.querySelectorAll('.screen').forEach(el => {
            el.classList.remove('active');
        });
        const target = document.getElementById(`screen-${screenName}`);
        if(target) {
            target.classList.add('active');
            target.scrollTop = 0; 
        }

        // クイズ画面が表示されたら、10秒のヒントタイマーを開始する
        if (screenName === 'quiz') {
            startHintTimer();
        } else {
            clearHintTimer(); 
        }
    }

    // ヒントタイマー開始関数
    function startHintTimer() {
        clearHintTimer(); 

        const bubble = document.getElementById('quiz-hint-bubble');
        bubble.classList.remove('hint-animate', 'opacity-100', 'scale-100');
        bubble.classList.add('opacity-0', 'scale-0');

        if(currentQuiz && currentQuiz.hint) {
            document.getElementById('quiz-hint-text').textContent = currentQuiz.hint;
            
            // 10秒（10000ミリ秒）後に吹き出しを出現させる
            hintTimer = setTimeout(() => {
                bubble.classList.remove('opacity-0', 'scale-0');
                bubble.classList.add('hint-animate');
            }, 10000);
        }
    }

    // ヒントタイマーリセット関数
    function clearHintTimer() {
        if (hintTimer) {
            clearTimeout(hintTimer);
            hintTimer = null;
        }
    }

    // キャンセルして戻る時の処理
    function cancelQuiz() {
        clearHintTimer();
        showScreen('top');
    }

    // 4. トップ画面の描画
    function renderMenuGrid() {
        const grid = document.getElementById('menu-grid');
        grid.innerHTML = ''; 

        menuData.forEach(item => {
            const tile = document.createElement('div');
            tile.className = "flex flex-col items-center tap-effect cursor-pointer group";
            tile.onclick = () => startQuiz(item.id);

            tile.innerHTML = `
                <div class="w-full aspect-square rounded-2xl mb-2.5 shadow-md border-2 border-white group-hover:border-primary overflow-hidden bg-white flex items-center justify-center relative">
                    <img src="${item.image}" alt="${item.name}" class="w-full h-full img-cover-center absolute inset-0" onerror="this.src='${fallbackImage}'; this.className='w-1/2 h-1/2 object-contain opacity-50 absolute top-1/4 left-1/4';">
                </div>
                <p class="text-[11px] font-bold text-center leading-tight text-gray-800 w-full truncate px-1 drop-shadow-sm">${item.name}</p>
            `;
            grid.appendChild(tile);
        });
    }

    // 5. 実食画面の開始 (クイズ画面の前に挟む)
    function startQuiz(menuId) {
        currentQuiz = menuData.find(item => item.id === menuId);
        if(!currentQuiz) return;

        document.getElementById('tasting-menu-name').textContent = currentQuiz.name;
        
        const tastingImg = document.getElementById('tasting-image');
        tastingImg.src = currentQuiz.image;
        tastingImg.className = "w-full h-full img-cover-center absolute inset-0"; 
        tastingImg.onerror = function() {
            this.src = fallbackImage;
            this.className = "w-1/2 h-1/2 object-contain opacity-50 absolute top-1/4 left-1/4";
        };

        document.getElementById('quiz-menu-name').textContent = currentQuiz.name;
        document.getElementById('quiz-question').textContent = currentQuiz.question;
        
        const optionsContainer = document.getElementById('quiz-options');
        optionsContainer.innerHTML = '';

        currentQuiz.options.forEach((optionText, index) => {
            const btn = document.createElement('button');
            btn.className = "w-full bg-white bg-opacity-95 border-2 border-white text-gray-800 font-bold py-5 px-5 rounded-2xl text-left shadow-md tap-effect text-[15px] active:border-secondary transition-colors flex items-center";
            btn.onclick = () => checkAnswer(index);
            
            btn.innerHTML = `
                <div class="w-10 h-10 rounded-md bg-gray-100 flex items-center justify-center mr-4 flex-shrink-0">
                    <img src="number${index + 1}.jpg" alt="${index + 1}" class="w-full h-full object-contain object-center" onerror="this.style.display='none';">
                </div>
                <span class="leading-tight">${optionText}</span>
            `;
            optionsContainer.appendChild(btn);
        });

        showScreen('tasting');
    }

    // 6. 回答の判定と結果画面の表示
    function checkAnswer(selectedIndex) {
        clearHintTimer(); 
        
        const isCorrect = (selectedIndex === currentQuiz.answerIndex);
        
        const header = document.getElementById('result-header');
        
        // 💡 変更箇所: SVGアイコンを廃止し、ok.jpg / zannen.jpg を丸カットなしの四角形（全体表示）で描画するように修正しました
        if (isCorrect) {
            header.innerHTML = `
                <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 mb-4 shadow-md border-4 border-white rounded-2xl overflow-hidden p-1.5">
                    <img src="ok.jpg" alt="正解アイコン" class="w-full h-full object-contain object-center mix-blend-multiply" onerror="this.style.display='none';">
                </div>
                <h2 class="text-3xl font-black text-green-600 tracking-widest drop-shadow-md">大正解！</h2>
            `;
        } else {
            header.innerHTML = `
                <div class="inline-flex items-center justify-center w-24 h-24 bg-red-50 mb-4 shadow-md border-4 border-white rounded-2xl overflow-hidden p-1.5">
                    <img src="zannen.jpg" alt="残念アイコン" class="w-full h-full object-contain object-center mix-blend-multiply" onerror="this.style.display='none';">
                </div>
                <h2 class="text-3xl font-black text-primary tracking-widest drop-shadow-md">ざんねん！</h2>
            `;
        }

        const matchedDrinks = currentQuiz.drinks;
        const randomDrinkObj = matchedDrinks[Math.floor(Math.random() * matchedDrinks.length)];

        document.getElementById('result-correct-answer').textContent = currentQuiz.options[currentQuiz.answerIndex];
        document.getElementById('result-explanation').textContent = currentQuiz.explanation;
        
        document.getElementById('result-drink-pairing').textContent = randomDrinkObj.name; 
        document.getElementById('result-drink-reason').textContent = randomDrinkObj.reason; 
        
        document.getElementById('result-recommend').innerHTML = currentQuiz.nextRecommend;

        showScreen('result');
    }
</script>

