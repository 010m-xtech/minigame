<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>味覚クイズ - お店のこだわり発見！</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#e63946', /* 提灯を思わせる赤 */
                        secondary: '#457b9d', /* 落ち着いた青 */
                        accent: '#f4a261', /* 温かみのあるオレンジ */
                        dark: '#1d3557', /* 深い紺色 */
                        light: '#f1faee' /* オフホワイト */
                    }
                }
            }
        }
    </script>
    <style>
        /* カスタムアニメーションと基本設定 */
        :root {
            /* セーフエリアのフォールバック値を変数化 */
            --sat: env(safe-area-inset-top, 0px);
            --sar: env(safe-area-inset-right, 0px);
            --sab: env(safe-area-inset-bottom, 0px);
            --sal: env(safe-area-inset-left, 0px);
        }

        body {
            -webkit-tap-highlight-color: transparent;
            /* テキスト選択やダブルタップズームを無効化してネイティブアプリっぽく */
            -webkit-user-select: none;
            user-select: none;
            touch-action: manipulation;
            /* スクロール時のバウンス効果を抑制（PWAでアプリっぽくする） */
            overscroll-behavior-y: none;
            background-color: #f3f4f6; /* ゲーム画面の外側は落ち着いたグレーに */
        }

        /* 入力欄などはテキスト選択・フォーカスを許可 */
        input, textarea {
            -webkit-user-select: auto;
            user-select: auto;
        }

        #app-container {
            max-width: 480px; /* スマホサイズに制限 */
            margin: 0 auto;
            min-height: 100vh;
            /* iOSのノッチやホームバー対応の余白 */
            padding-top: var(--sat);
            padding-bottom: var(--sab);
            padding-left: var(--sal);
            padding-right: var(--sar);
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden; /* 背景画像のはみ出しを防ぐ */
            display: flex;
            flex-direction: column;
        }

        .screen {
            display: none;
            flex-grow: 1;
            padding: 1.25rem;
            /* 画面単位でのスクロールを制御 */
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }
        .screen.active {
            display: none; 
        }
        
        #screen-top.screen.active,
        #screen-quiz.screen.active,
        #screen-result.screen.active {
            display: flex;
            flex-direction: column;
            animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        #screen-tasting.screen.active {
            display: flex;
            flex-direction: column;
            justify-content: center;
            animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* ゆっくりふわっと出るアニメーション(実食画面用) */
        @keyframes slowFadeIn {
            from { opacity: 0; transform: scale(0.97); }
            to { opacity: 1; transform: scale(1); }
        }
        .slow-fade {
            animation: slowFadeIn 0.6s ease-out forwards;
        }
        
        /* タップ時のフィードバック */
        .tap-effect {
            transition: transform 0.1s, opacity 0.1s;
        }
        .tap-effect:active {
            transform: scale(0.95);
            opacity: 0.8;
        }

        /* 画像が長方形だった場合に中央を切り抜くスタイル */
        .img-cover-center {
            object-fit: cover;
            object-position: center;
        }

        /* ヒント吹き出しのポップアップアニメーション（フクロウのいる右側へ向かって広がる） */
        @keyframes hintPopUp {
            0% {
                opacity: 0;
                transform: scale(0) translate(20px, 0);
            }
            70% {
                transform: scale(1.05) translate(-2px, 0);
            }
            100% {
                opacity: 1;
                transform: scale(1) translate(0, 0);
            }
        }
        .hint-animate {
            animation: hintPopUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            transform-origin: right center; /* フクロウ側（右）を起点に広がる */
        }
    </style>
</head>
