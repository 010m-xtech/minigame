<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>かき太郎探しゲーム</title>
    <style>
        body {
            font-family: sans-serif;
            background: #fff8e1;
            text-align: center;
            padding: 20px;
            margin: 0;
            user-select: none;
        }
        /* ゲームの土台（かき太郎いっぱいを背景にセット） */
        .game-container {
            position: relative;
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            border-radius: 10px;
            overflow: hidden;
            
            background-image: url("かき太郎いっぱい.png");
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            
            /* 800 x 1326 の比率を完全に固定 */
            aspect-ratio: 800 / 1326; 
        }
        /* 正解シートの設定 */
        .overlay-sheet {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            object-fit: contain;
            z-index: 15;
        }
        /* 正解シートが表示された時用 */
        .overlay-sheet.active-success {
            display: block;
        }
        /* 🎯 正解エリア（右下の本物のかき太郎の位置） */
        .target-area {
            position: absolute;
            cursor: pointer;
            left: 68.75%;  /* (620px - 70px) / 800px */
            top: 82.20%;   /* (1205px - 115px) / 1326px */
            width: 17.50%; /* 140px / 800px */
            height: 17.34%;/* 230px / 1326px */
            border: 2px solid transparent; /* 位置を確認したい時は transparent を red に変えてください */
            z-index: 10;
        }
        /* 全体ロック用カバー */
        .lock-cover {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            background: rgba(0,0,0,0);
            z-index: 20;
        }
        .lock-cover.active {
            display: block;
        }
    </style>
</head>
<body>

<h1>本物の「かき太郎」を探せ！</h1>
<p>本物のかき太郎を見つけてタップしてね。</p>

<div class="game-container" id="gameContainer">

    <div class="target-area" id="targetArea" onclick="handleCorrect(event)"></div>

    <img src="正解シート.png" class="overlay-sheet" id="successSheet" alt="正解">

    <div class="lock-cover" id="lockCover"></div>
</div>

<script>
    // 正解した時の処理
    function handleCorrect(event) {
        event.stopPropagation();
        
        // コメント（alert）は出さずに、正解シートだけを即座に表示
        document.getElementById('successSheet').classList.add('active-success');
        
        // 全体を完全にロックしてこれ以上触らせない
        document.getElementById('lockCover').classList.add('active');
    }
</script>

</body>
</html>
